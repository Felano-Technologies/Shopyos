# =====================================================
# SHOPYOS BACKEND - ENV EXAMPLE
# Copy to .env and replace values
# =====================================================

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRE=30d
APP_SCHEME=shopyos

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shopyos
PG_POOL_MIN=2
PG_POOL_MAX=10
# Optional: set true if your provider requires SSL, false if it does not support SSL.
PG_SSL=false

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=you@example.com
EMAIL_FROM_NAME=Shopyos

# Object Storage (Sevalla S3-compatible)
STORAGE_ENDPOINT=https://s3.sevalla.example
STORAGE_REGION=us-east-1
STORAGE_BUCKET=shopyos-assets
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_PUBLIC_URL=https://cdn.sevalla.example/shopyos-assets

# SMS (Arkesel)
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=Shopyos

# Payments (Paystack)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Frontend URL (CORS / links)
FRONTEND_URL=http://localhost:8081

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ / CloudAMQP
RABBITMQ_URL=amqp://localhost
# CLOUDAMQP_URL=amqps://user:pass@host/vhost

# Realtime bridge (backend -> standalone socket service)
REALTIME_EVENTS_CHANNEL=shopyos:realtime:events
ENABLE_LOCAL_SOCKET=false

# Logging / CORS
LOG_LEVEL=debug
CORS_ORIGINS=*
