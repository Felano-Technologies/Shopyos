# =====================================================
# INFRASTRUCTURE (Local Docker Dev)
# =====================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shopyos
DB_PORT=5433

REDIS_PASSWORD=redis
REDIS_PORT=6380

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=shopyos-assets

# =====================================================
# SERVER PORTS (Host & Internal)
# =====================================================
BACKEND_PORT=5000
SOCKET_PORT=5001
NODE_ENV=development

# =====================================================
# SHARED CONFIGURATION
# =====================================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d
FRONTEND_URL=http://localhost:8081
REALTIME_EVENTS_CHANNEL=shopyos:realtime:events

# Database & Redis connectivity
# Local dev uses these (internal docker network):
DATABASE_URL=postgres://postgres:postgres@db:5432/shopyos
REDIS_URL=redis://:redis@redis:6379/0

# =====================================================
# BACKEND SPECIFIC
# =====================================================
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_SSL=false

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=Shopyos

# Object Storage (S3-compatible)
STORAGE_ENDPOINT=http://storage:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000/shopyos-assets

# External APIs
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=Shopyos
PAYSTACK_SECRET_KEY=your_paystack_secret
PAYSTACK_PUBLIC_KEY=your_paystack_public

# Logging
LOG_LEVEL=debug
CORS_ORIGINS=*

# RabbitMQ
RABBITMQ_URL=your_rabbitmq_url

# Other
ENABLE_LOCAL_SOCKET=false
ALLOW_SEED=true

GEMINI_API_KEY=your_gemini_key

# Admin User Defaults
ADMIN_EMAIL=shoyosecommercehub@gmail.com
ADMIN_PASSWORD=your_secure_password_here