# =====================================================
# SHOPYOS FRONTEND - ENV EXAMPLE
# Copy to .env and replace values
# =====================================================

# Set to true to use local dev URLs, false to use Railway production URLs
EXPO_PUBLIC_DEV_MODE=false

# Production URLs (Railway)
EXPO_PUBLIC_API_URL=https://shopyos-production.up.railway.app
EXPO_PUBLIC_SOCKET_URL=https://shopyos-production.up.railway.app

# Dev URLs (local)
EXPO_PUBLIC_DEV_API_URL=http://localhost:5000
EXPO_PUBLIC_DEV_SOCKET_URL=http://localhost:5001
