{
  "expo": {
    "name": "Shopyos",
    "slug": "shopyos",
    "owner": "eugeneanokye99",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon.png",
    "scheme": "shopyos",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to track deliveries in real-time for better customer experience.",
        "NSLocationWhenInUseUsageDescription": "We need your location to provide accurate delivery services.",
        "NSMicrophoneUsageDescription": "Allow Shopyos to access your microphone for voice calls.",
        "UIBackgroundModes": [
          "location",
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.eugeneanokye99.shopyos",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "WRITE_EXTERNAL_STORAGE", 
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/adaptive-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Shopyos to track your location during deliveries for real-time updates.",
          "locationAlwaysPermission": "Allow Shopyos to track your location in the background during active deliveries.",
          "locationWhenInUsePermission": "Allow Shopyos to access your location to provide better service.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Shopyos to access your camera"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icondark.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Shopyos to access your camera",
          "microphonePermission": "Allow Shopyos to access your microphone"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce559e8d-1b1f-4182-9129-a1e0bf653b92"
      }
    }
  }
}
