# Copy this file to .env.compose and customize values for local Docker

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shopyos
DB_PORT=5432

# Redis
REDIS_PASSWORD=change-me
REDIS_PORT=6380

# MinIO (Object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=shopyos-assets
STORAGE_PUBLIC_URL=http://localhost:9000/shopyos-assets

# App ports
BACKEND_PORT=5000
SOCKET_PORT=5001
